# Copy this file to .env and fill in your own values. Never commit .env itself.

PORT=5000

# Local MongoDB, or a free MongoDB Atlas cluster connection string
MONGO_URI=mongodb://127.0.0.1:27017/nutrition_assistant

# Any long random string — used to sign JWT auth tokens
JWT_SECRET=replace_this_with_a_long_random_secret

# How long a login token stays valid
JWT_EXPIRES_IN=7d
